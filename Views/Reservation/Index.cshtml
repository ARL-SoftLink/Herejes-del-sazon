@model herejes_del_sazon.Models.ViewModels.ReservationViewModel

@{
    ViewData["Title"] = "Reservaciones";
}

<section class="container-custom">

    <div class="section-header">

        <h1>Reservaciones</h1>

        <p>
            Reserva tu mesa y disfruta de una experiencia gastronómica única en Herejes del Sazón.
        </p>

    </div>

    <div class="reservation-container">

        <h2>Próximamente</h2>

        <p>
            En esta sección podrás seleccionar una mesa, elegir la fecha y hora de tu reserva y completar tus datos.
        </p>

        <hr class="detail-divider" />

        <h2>Mesas disponibles</h2>

        <div class="table-grid">

            @foreach (var mesa in Model.Mesas)
            {
              <partial name="Components/_TableCard"
               model="mesa" />
            }

        </div>

        <hr class="detail-divider"/>

        <section class="reservation-form">

         <h2>Completa tu reservación</h2>
            
            <div class="selected-table-info">

               <strong>Mesa seleccionada:</strong>

                <span id="selectedTableName">

                   Ninguna

                </span>

            </div>

            @if (TempData["Success"] != null)
            {
               <div class="alert alert-success">

                  @TempData["Success"]

                </div>
            }

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <form id="reservationForm"
                  asp-controller="Reservation"
                  asp-action="Create"
                method="post">

                <div asp-validation-summary="ModelOnly"
                    class="text-danger mb-3">
                </div>


                <input asp-for="IdMesa" type="hidden" id="selectedTableId" />

                <div class="form-group">

                    <label>Nombre</label>

                    <input asp-for="NombreCliente"
                    class="form-control"/>

                    <span asp-validation-for="NombreCliente"
                         class="text-danger"></span>

                </div>

                <div class="form-group">

                  <label>Correo electrónico</label>

                    <input asp-for="Correo"
                            class="form-control"/>

                    <span asp-validation-for="Correo"
                         class="text-danger"></span>

                </div>

                <div class="form-group">

                     <label>Teléfono</label>

                     <input asp-for="Telefono"
                       class="form-control"/>

                    <span asp-validation-for="Telefono"
                          class="text-danger"></span>

                </div>


                <div class="form-group">

                   <label>Fecha</label>

                  <input asp-for="Fecha"
                     type="date"
                     class="form-control"/>

                  <span asp-validation-for="Fecha"
                       class="text-danger"></span>

                </div>

                <div class="form-group">

                 <label>Hora</label>

                   <input asp-for="Hora"
                         type="time"
                         class="form-control"/>
                    
                    <span asp-validation-for="Hora"
                          class="text-danger"></span>

                </div>

                <div class="form-group">

                  <label>Número de personas</label>

                   <input asp-for="Personas"
                        type="number"
                        min="1"
                       class="form-control"/>
                    
                    <span asp-validation-for="Personas"
                        class="text-danger"></span>

                </div>

                <div class="form-group">

                  <label>Observaciones</label>

                   <textarea asp-for="Observaciones"
                            rows="4"
                            class="form-control"
                            placeholder="Ejemplo: Celebración de cumpleaños, silla para bebé, alergias, etc.">
                    </textarea>

                </div>

                <div class="form-actions">

                  <button type="submit"
                    class="btn-primary-custom">

                   Reservar mesa

                   </button>

                </div>

            </form>

        </section>

    </div>

</section>

@section Scripts{

    <partial name="_ValidationScriptsPartial"/>

}
