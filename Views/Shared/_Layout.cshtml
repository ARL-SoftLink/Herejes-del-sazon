<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Herejes del Sazón</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- CSS Global -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />

    <!-- Estilos generados por ASP.NET -->
    <link rel="stylesheet" href="~/herejes_del_sazon.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

@{
    var tieneHero = ViewData["HasHero"] as bool? ?? false;
}
<body class="@(tieneHero ? "has-hero" : "")">

    <!-- ========================= -->
    <!-- HEADER -->
    <!-- ========================= -->

    <header>

        <nav id="mainNavbar"
             class="navbar navbar-expand-lg fixed-top">

            <div class="container">

                <!-- Logo -->

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    Herejes del Sazón

                </a>

                <!-- Botón Responsive -->

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMenu">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <!-- Menú -->

                <div class="collapse navbar-collapse"
                     id="navbarMenu">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Menu"
                               asp-controller="Index">

                                Menú

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Reservation"
                               asp-action="Index">

                                Reservaciones

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="#">

                                Pedidos

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="#">

                                Nosotros

                            </a>

                        </li>

                        <li class="nav-item">

                            
                            <a class="nav-link"
                               asp-controller="Auth"
                               asp-action="Login">
                                Iniciar sesión
                            </a>                         

                        </li>

                        <li class="nav-item">
                          <a class="nav-link"
                             asp-controller="Auth"
                             asp-action="Register">
                              Registrarse
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- ========================= -->
    <!-- CONTENIDO -->
    <!-- ========================= -->

    <main>

        @RenderBody()

    </main>

    <!-- ========================= -->
    <!-- FOOTER -->
    <!-- ========================= -->

    <footer>

        <div class="container">

            <p>

                © 2026 Herejes del Sazón

            </p>

        </div>

    </footer>

    <!-- Bootstrap -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JavaScript propio -->

    <script src="~/js/layout.js" asp-append-version="true"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/js/reservation.js" asp-append-version="true"></script>

</body>

</html>